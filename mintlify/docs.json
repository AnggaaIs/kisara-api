{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Kisara API Documentation",
  "description": "Official API reference and documentation for Kisara API",
  "theme": "maple",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0ea5e9",
    "light": "#38bdf8",
    "dark": "#0c4a6e"
  },
  "appearance": {
    "default": "dark",
    "dark": true,
    "light": true
  },
  "background": {
    "decoration": "gradient"
  },
  "fonts": {
    "heading": {
      "family": "Manrope",
      "weight": 700
    },
    "body": {
      "family": "Manrope",
      "weight": 500
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "tokyo-night"
      },
      "showLineNumbers": true
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:title": "Kisara API Documentation",
      "og:description": "Official API reference for Kisara",
      "og:image": "/images/og-banner.png",
      "og:url": "https://kisara.my.id"
    }
  },
  "search": {
    "prompt": "Search documentation...",
    "mode": "flexible"
  },
  "metadata": {
    "timestamp": true
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true,
    "thumbs": true
  },
  "contextual": {
    "options": ["copy", "view", "claude", "chatgpt"],
    "display": "header"
  },
  "navbar": {
    "links": [
      {
        "href": "https://github.com/AnggaaIs/kisara-api",
        "type": "github"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/api/overview"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://kisara.my.id"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/AnggaaIs/kisara-api"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "rocket",
            "pages": ["index", "introduction", "quickstart"]
          },
          {
            "group": "Core Concepts",
            "icon": "cpu",
            "pages": ["authentication", "rate-limits", "errors"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi/openapi.json"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/AnggaaIs/kisara-api",
      "website": "https://kisara.my.id"
    }
  },
  "api": {
    "playground": {
      "display": "interactive",
      "mode": "explore",
      "auth": "bearer"
    },
    "params": {
      "expanded": "all"
    },
    "url": "full",
    "examples": {
      "languages": ["curl", "javascript", "python", "go"],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    },
    "spec": {
      "download": true
    }
  }
}

