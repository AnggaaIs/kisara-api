{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Kisara API Documentation",
  "description": "Developer-focused API docs for reliable, secure, and production-ready Kisara integrations.",
  "theme": "maple",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg"
  },
  "favicon": "/favicon.svg",
  "colors": {
    "primary": "#0284c7",
    "light": "#38bdf8",
    "dark": "#082f49"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "decoration": "gradient"
  },
  "fonts": {
    "heading": {
      "family": "Space Grotesk",
      "weight": 700
    },
    "body": {
      "family": "Plus Jakarta Sans",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": {
      "theme": {
        "light": "github-light",
        "dark": "tokyo-night"
      }
    }
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:title": "Kisara API Documentation",
      "og:description": "Official API reference and developer guides for Kisara.",
      "og:image": "/images/og-banner.png",
      "og:url": "https://kisara.my.id",
      "twitter:card": "summary_large_image"
    }
  },
  "search": {
    "prompt": "Search docs..."
  },
  "metadata": {
    "timestamp": true
  },
  "thumbnails": {
    "appearance": "dark",
    "fonts": {
      "family": "Space Grotesk"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt"
    ],
    "display": "header"
  },
  "interaction": {
    "drilldown": true
  },
  "navbar": {
    "links": [
      {
        "href": "https://github.com/AnggaaIs/kisara-api",
        "type": "github"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Start Integrating",
      "href": "/api/overview"
    }
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Playground",
          "icon": "terminal",
          "href": "/api/overview"
        },
        {
          "anchor": "Website",
          "icon": "globe",
          "href": "https://kisara.my.id"
        },
        {
          "anchor": "GitHub",
          "icon": "github",
          "href": "https://github.com/AnggaaIs/kisara-api"
        }
      ]
    },
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Foundations",
            "icon": "rocket",
            "pages": [
              "index",
              "api/overview"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi/openapi.json"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/AnggaaIs/kisara-api",
      "website": "https://kisara.my.id"
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    },
    "url": "full",
    "examples": {
      "languages": [
        "curl",
        "javascript",
        "python",
        "go",
        "php"
      ],
      "defaults": "required",
      "prefill": true,
      "autogenerate": true
    }
  }
}